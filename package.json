{
	"name": "@pawells/mcp-memory",
	"displayName": "MCP Memory",
	"version": "1.4.3",
	"description": "Model Context Protocol server for semantic memory and knowledge management with Claude Code",
	"type": "module",
	"main": "./build/index.js",
	"bin": "./build/index.js",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"default": "./build/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"start": "node build/index.js",
		"dev": "tsc && node build/index.js",
		"watch": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"pipeline": "yarn typecheck && yarn lint && yarn test:coverage && yarn build",
		"prepublishOnly": "yarn build",
		"prepare": "husky"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@pawells/logger": "^1.2.2",
		"@qdrant/js-client-rest": "^1.17.0",
		"dotenv": "^17.4.2",
		"openai": "^6.34.0",
		"undici": "^8.1.0",
		"uuid": "^14.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"eslint": "^10.2.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"typescript": "~6.0.0",
		"vitest": "^4.1.5"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"semantic-memory",
		"vector-search",
		"claude",
		"claude-code",
		"knowledge-management",
		"qdrant",
		"openai",
		"embeddings",
		"ai-memory",
		"ai"
	],
	"author": "Phillip Aaron Wells",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PhillipAWells/mcp-memory.git"
	},
	"bugs": {
		"url": "https://github.com/PhillipAWells/mcp-memory/issues"
	},
	"homepage": "https://github.com/PhillipAWells/mcp-memory#readme",
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "yarn@4.12.0",
	"files": [
		"build",
		"rules",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	}
}