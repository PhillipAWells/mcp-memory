# OpenAI API Configuration (required)
OPENAI_API_KEY=sk-your-api-key-here

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=mcp-memory
QDRANT_TIMEOUT=30000

# Server Configuration
LOG_LEVEL=info

# Memory Configuration
MEMORY_CHUNK_SIZE=1000
MEMORY_CHUNK_OVERLAP=200

# Large embedding dimensions (OpenAI provider only — text-embedding-3-large)
LARGE_EMBEDDING_DIMENSIONS=3072

# Workspace Configuration
WORKSPACE_AUTO_DETECT=true
WORKSPACE_DEFAULT=
WORKSPACE_CACHE_TTL=60000

# Rules Configuration
COPY_CLAUDE_RULES=true

# =============================================================================
# Proxy Configuration
# =============================================================================
# Standard HTTP(S) proxy environment variables are supported.
# When set, ALL outbound fetch traffic (OpenAI API, Qdrant, HuggingFace model
# downloads) is routed through the specified proxy using Node.js built-in
# undici EnvHttpProxyAgent — no additional dependencies required.
#
# NO_PROXY is automatically defaulted to "localhost,127.0.0.1,::1" when a
# proxy is active and NO_PROXY is not set — protecting local Qdrant traffic
# without any manual configuration. Set NO_PROXY explicitly to override.
#
# Lowercase variants (https_proxy, http_proxy, no_proxy) are also accepted;
# uppercase takes priority.
#
#HTTPS_PROXY=http://proxy.example.com:8080
#HTTP_PROXY=http://proxy.example.com:8080
#NO_PROXY=localhost,127.0.0.1,::1
